#!/bin/bash

export MY_REPOS="$HOME/repos/enricava"
export DOTFILES="$HOME/dotfiles"

# =============================================================================
# PROMPT
# =============================================================================
eval "$(starship init bash)"

# =============================================================================
# PATH
# =============================================================================
export PATH="$PATH:/opt/nvim-linux64/bin"
export PATH="$PATH:~/go/bin"
export PATH="$PATH:/usr/local/android-studio/bin"
export PATH="$PATH:/usr/bin/flutter/bin"

# =============================================================================
# ALIASES
# =============================================================================
alias repo="cd $MY_REPOS"
alias dotfiles="cd $DOTFILES"

alias v='nvim'
alias vim='nvim'
alias python='python3'

# Share files over http
alias share='ip a && python3 -m http.server'

# Fzf helpers
alias ff='fzf --preview="bat {} --color always" --preview-window=down'

# Tmux environments
alias tmater=". $DOTFILES/scripts/tmux_startup.sh                             \
  -n matermap                                                                 \
  -matermap $MY_REPOS/matermap/mobile-app :                                  \
  -materpet $MY_REPOS/matermap/materpet :                                    \
  -core-utils $MY_REPOS/matermap/core-utils :                                \
  -dotfiles   $DOTFILES                     :                                \
  "

# =============================================================================
# OTHER
# =============================================================================
# Rust shenanigans
. "$HOME/.cargo/env"
if [ -f /opt/nvim-linux64/bin/nvim ]; then
    export EDITOR=/opt/nvim-linux64/bin/nvim
fi

# =============================================================================
# AUTOCOMPLETE
# =============================================================================
if [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
fi
